# 复制为 .env 后填入实际值
APP_NAME=Hunter Radar V1.4
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://hunter:hunter@localhost:5432/hunter_radar
DATABASE_URL_SYNC=postgresql+psycopg2://hunter:hunter@localhost:5432/hunter_radar

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=dev-only-change-me-in-prod-32-bytes-min
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Stripe(可选,开发期留空)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# Web Push VAPID(可选,开发期留空)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=

# Sentry
SENTRY_DSN=

# Threat Score
THREAT_RED_THRESHOLD=70
THREAT_RED_THRESHOLD_PANIC=80
EMA_HALFLIFE_DAYS=2

# Backtest
BACKTEST_HISTORY_YEARS=2
BACKTEST_GOLDSET_MIN_EVENTS=30

# Quota
FREE_TIER_DAILY_QUOTA=3
