# 顶层 .gitignore — Hunter Radar 项目上传到 GitHub
# 此文件覆盖整个工作区(Hunter Radar 顶层),递归应用到所有子目录

# 排除 sandbox 测试数据(任意层级)
**/data/

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/
htmlcov/
.coverage
.env
.env.local

# 前端
node_modules/
dist/
.pnpm-store/
*.local
.vite/

# IDE
.idea/
.vscode/
.DS_Store

# 数据
*.db
*.sqlite3
*.log

# 临时测试输出
backend/scripts/m*t*_test_output*.log
backend/scripts/m*t*_output*.log
backend/scripts/m8t1_v*_run.log

# 本地运行时产生的数据/配置
.pg-data/
.redis-bundle/
.redis-config.conf
.redis-data/
init_pg.sh

# 锁文件（平台无关，项目用 uv/pnpm 管理）
package-lock.json
pnpm-lock.yaml
uv.lock

# 编译产物
*.tsbuildinfo
*.js.map
vite.config.d.ts
vite.config.js

# Playwright 输出
test-results/
playwright-report/
blob-report/
.playwright/

# 自动生成的静态路由表（项目有 routeTree.ts 作为源）
routeTree.gen.ts

# .deb 等无关系统文件
*.deb

# Qoder IDE 缓存
.qoder/
